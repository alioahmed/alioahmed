{
  "name": "alioahmed",
  "version": "2.0.0",
  "private": true,
  "description": "Personal site of Ali Ahmed — AI Solutions Engineer. Next.js (App Router) on Vercel.",
  "scripts": {
    "dev": "next dev",
    "prebuild": "npm run gen:page-dates",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "typecheck:scripts": "tsc -p tsconfig.scripts.json",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "validate:jsonld": "node scripts/validate-jsonld.mjs",
    "validate:jsonld:deep": "node scripts/validate-jsonld-deep.mjs",
    "check": "npm run typecheck && npm run lint && npm run check:guardrails && npm run build",
    "check:unused": "knip",
    "check:guardrails": "npx tsx scripts/check-guardrails.ts",
    "check:canonical-trace": "npx tsx scripts/check-canonical-trace.ts",
    "check:entity": "npx tsx scripts/check-entity-consistency.ts",
    "gen:page-dates": "npx tsx scripts/generate-page-dates.ts",
    "gen:llms-full": "npx tsx scripts/generate-llms-full.ts",
    "check:last-updated": "npx tsx scripts/check-last-updated.ts",
    "check:freshness-drift": "npx tsx scripts/check-freshness-drift.ts",
    "check:jsonld-validity": "npx tsx scripts/check-jsonld-validity.ts",
    "check:answer-structure": "npx tsx scripts/check-answer-structure.ts",
    "check:internal-links": "npx tsx scripts/check-internal-links.ts",
    "check:indexing-drift": "npx tsx scripts/check-indexing-drift.ts",
    "check:growth": "npx tsx scripts/check-guardrails.ts && npx tsx scripts/check-jsonld-validity.ts && npx tsx scripts/check-answer-structure.ts && npx tsx scripts/check-internal-links.ts && npx tsx scripts/check-freshness-drift.ts",
    "seo:audit": "npx tsx scripts/schema-audit.ts",
    "seo:audit:full": "npx tsx scripts/schema-audit.ts --full",
    "seo:canonicals": "npx tsx scripts/canonical-audit.ts",
    "seo:og-images": "npx tsx scripts/og-image-audit.ts",
    "seo:images": "npx tsx scripts/image-audit.ts",
    "seo:metadata": "node scripts/validate-metadata.js",
    "seo:audit:prod": "npx tsx scripts/canonical-audit.ts && npx tsx scripts/og-image-audit.ts && npx tsx scripts/check-internal-links.ts",
    "seo:llm": "npx tsx scripts/llm-check.ts",
    "seo:ai-overview": "npx tsx scripts/ai-overview-track.ts",
    "seo:indexnow": "npx tsx scripts/indexnow-submit.ts",
    "indexnow:on-change": "npx tsx scripts/indexnow-on-change.ts",
    "seo:submit": "npx tsx scripts/gsc-submit.ts full",
    "seo:report": "npx tsx scripts/gsc-report.ts",
    "seo:bing": "npx tsx scripts/bing-webmaster.ts",
    "seo:bing:submit": "npx tsx scripts/bing-webmaster.ts submit",
    "seo:ga4-vitals": "npx tsx scripts/ga4-page-vitals.ts",
    "seo:verify-sa": "npx tsx scripts/verify-sa-access.ts"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.22.0",
    "next": "16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.9",
    "knip": "^5.66.1",
    "prettier": "^3.8.2",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "postcss": "^8.5.16"
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
