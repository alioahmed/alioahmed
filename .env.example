# Public site URL (used for metadataBase, canonical, sitemap, schema @id roots).
# Defaults to the Vercel preview URL until a custom domain is chosen.
NEXT_PUBLIC_SITE_URL=https://alioahmed.com

# IndexNow key — instant Bing/ChatGPT-index pinging. Generate a random hex string,
# then also create public/<KEY>.txt containing the same key.
INDEXNOW_KEY=

# Google Analytics 4 measurement id (G-XXXXXXXXXX). Leave blank to disable GA.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Search-engine verification tokens (meta tags). Leave blank if unused.
# Google → Search Console · Bing → Webmaster Tools · Yandex → Webmaster.
# (Brave has no meta token — submit the sitemap at search.brave.com/submit-url instead.)
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
YANDEX_SITE_VERIFICATION=

# ─────────────────────────────────────────────────────────────────────────────
# SEO/GEO/AEO operations scripts (scripts/*). All DORMANT until set — every
# script that needs one of these no-ops with a clear notice when it's absent.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL the localhost/prod audits target. Defaults to http://localhost:3000
# for the audit scripts (and NEXT_PUBLIC_SITE_URL for submission scripts).
# BASE_URL=http://localhost:3000

# Google Search Console — service-account JSON path + property.
# Create a service account, enable the Search Console + Indexing APIs, download
# the JSON key, save it to credentials/google-service-account.json (gitignored),
# and add the SA email as an Owner in Search Console.
GOOGLE_APPLICATION_CREDENTIALS=credentials/google-service-account.json
# GSC property. Domain property form: sc-domain:<host>. Defaults to sc-domain:<host>.
GSC_SITE=

# Bing Webmaster Tools API key (Settings → API Access → API Key).
BING_API_KEY=

# Google Analytics 4 — numeric property id (e.g. 529702052) for the GA4 Data API
# (real-user CWV via ga4-page-vitals.ts). Blank = GA4 scripts stay dormant.
GA4_PROPERTY_ID=

# PageSpeed Insights API key — OPTIONAL. PSI works keyless at low volume; only
# set this if you hit rate limits during --cwv audits.
PAGESPEED_API_KEY=

# AI-visibility trackers (llm-check.ts, ai-overview-track.ts) — all optional.
# OpenRouter gives Perplexity + OpenAI + Anthropic behind one key/bill.
OPENROUTER_API_KEY=
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
SERPAPI_KEY=

# Vercel API (reserved for future deploy-time automation). Optional.
VERCEL_TOKEN=
VERCEL_TEAM_SLUG=

# Wikidata QID for the entity drift-check (check:entity). Blank = dormant.
# Set once the Wikidata item exists (see docs/IDENTITY.md).
WIKIDATA_QID=
